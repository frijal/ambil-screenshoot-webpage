{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["@google/generative-ai", "sharp"],
      "groupName": "core-dependencies"
    }
  ],
  "enabledManagers": ["bun", "github-actions"],
  "bun": {
    "enabled": true
  },
  "constraints": {
    "bun": "latest"
  },
  "postUpdateOptions": [
    "bun-lockfile-fix"
  ]
}
